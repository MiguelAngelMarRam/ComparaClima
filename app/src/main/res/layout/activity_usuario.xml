<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/transparent"
    android:gravity="center_horizontal">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#EE1976D2"> <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="25dp">

        <TextView
            android:id="@+id/tvBienvenida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hola_usuario"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="¿CUÁL SERÁ TU PRÓXIMO DESTINO IDEAL?"
            android:textColor="#E3F2FD"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnComparar"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginBottom="15dp"
        android:text="NUEVA COMPARACIÓN"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#CCFFFFFF"
        android:textColor="#1976D2"
        app:strokeColor="#1976D2"
        app:strokeWidth="2dp"
        app:cornerRadius="15dp"
        android:drawableLeft="@android:drawable/ic_menu_search"
        android:paddingLeft="20dp"
        android:elevation="4dp"/>

    <Button
        android:id="@+id/btnConfiguracion"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginBottom="15dp"
        android:text="AJUSTE DE GUSTOS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#CCFFFFFF"
        android:textColor="#1976D2"
        app:strokeColor="#1976D2"
        app:strokeWidth="2dp"
        app:cornerRadius="15dp"
        android:drawableLeft="@android:drawable/ic_menu_manage"
        android:paddingLeft="20dp"
        android:elevation="4dp"/>

    <Button
        android:id="@+id/btnHistorial"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginBottom="40dp"
        android:text="MI HISTORIAL"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#CCFFFFFF"
        android:textColor="#1976D2"
        app:strokeColor="#1976D2"
        app:strokeWidth="2dp"
        app:cornerRadius="15dp"
        android:drawableLeft="@android:drawable/ic_menu_recent_history"
        android:paddingLeft="20dp"
        android:elevation="4dp"/>

    <View
        android:layout_width="100dp"
        android:layout_height="2dp"
        android:background="#88FFFFFF"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CERRAR SESIÓN"
        android:textStyle="bold"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        app:cornerRadius="10dp"
        style="@style/Widget.MaterialComponents.Button.Icon"/>

</LinearLayout>